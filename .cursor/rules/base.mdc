# 7. JavaScript 규칙

- jQuery 우선 사용, 필요 시 순수 JavaScript 대체
- ES6+ 문법 및 모듈화 적용
- 반복 코드는 함수화, 동일 패턴 UI는 컴포넌트 단위로 분리
- `var` 사용 금지 → `const` / `let`
- `console.log()` / `alert()` 배포 코드에 잔존 금지

```js
$(function () {
  const initToggle = ($root, { button = '.js-toggle', panel = '.js-panel' } = {}) => {
    const $btn = $root.find(button);
    const $panel = $root.find(panel);
    if (!$btn.length || !$panel.length) return;

    const set = (open) => {
      $btn.attr('aria-expanded', open);
      $panel.attr('aria-hidden', !open);
      $root.toggleClass('is-open', open);
    };

    set($btn.attr('aria-expanded') === 'true');
    $btn.on('click', (e) => { e.preventDefault(); set($btn.attr('aria-expanded') !== 'true'); });
    $btn.on('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); $btn.trigger('click'); }
      else if (e.key === 'Escape') set(false);
    });
  };

  $('.c-toggle').each((_, el) => initToggle($(el)));
});
```

